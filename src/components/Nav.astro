---
import { ShieldCheck, ChevronDown, PhoneCall } from 'lucide-react';
const currentPath = Astro.url.pathname;

const dropdowns = [
  {
    label: 'Services',
    href: '/services',
    items: [
      { href: '/ada-compliance-audit-small-business', label: 'Small Business Audit' },
      { href: '/ada-compliance-audit-pricing', label: 'Pricing & Tax Credit' },
      { href: '/vpat-documentation-services', label: 'VPAT Documentation' },
      { href: '/how-to-make-pdf-ada-compliant', label: 'PDF Remediation' },
      { href: '/accessibility-statement-template', label: 'Accessibility Statement' },
    ]
  },
  {
    label: 'Industries',
    href: '/industries',
    items: [
      { href: '/ada-compliance-ecommerce-websites', label: 'E-commerce' },
      { href: '/ada-compliance-shopify', label: 'Shopify' },
      { href: '/ada-compliance-healthcare-websites', label: 'Healthcare' },
      { href: '/ada-compliance-restaurants', label: 'Restaurants' },
      { href: '/ada-compliance-law-firms', label: 'Law Firms' },
      { href: '/ada-compliance-dental-offices', label: 'Dental Offices' },
      { href: '/ada-compliance-for-nonprofits', label: 'Nonprofits' },
    ]
  },
  {
    label: 'Resources',
    href: '/what-is-ada-compliance-websites',
    items: [
      { href: '/what-is-ada-compliance-websites', label: 'What Is ADA Compliance?' },
      { href: '/received-ada-demand-letter', label: 'Got a Demand Letter?' },
      { href: '/accessibility-overlay-alternatives', label: 'Overlay Alternatives' },
      { href: '/wcag-2-1-vs-wcag-2-2', label: 'WCAG 2.1 vs 2.2' },
      { href: '/section-508-compliance', label: 'Section 508 Guide' },
      { href: '/disabled-access-credit-tax', label: 'Tax Credit Guide' },
      { href: '/ada-compliance-checklist-2026', label: 'ADA Checklist 2026' },
      { href: '/ada-compliance-faq', label: 'FAQ Hub' },
    ]
  },
];

const showAbout = true;
---

<header class="site-nav" id="site-header">
  <div class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo">
      <ShieldCheck className="lucide-icon logo-icon" aria-hidden="true" size={20} strokeWidth={2} />
      <span class="logo-text">comply<strong>Tech</strong><span class="sr-only"> - ADA Compliance Services</span></span>
    </a>

    <!-- Nav Links -->
    <nav class="nav-links" aria-label="Main navigation">
      <a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`} aria-current={currentPath === '/' ? 'page' : undefined}>Home</a>
      {dropdowns.map((dd) => (
        <div class="nav-dropdown">
          <a
            href={dd.href}
            class={`nav-link nav-link-dd ${dd.items.some(i => i.href === currentPath) || currentPath === dd.href ? 'active' : ''}`}
          >
            {dd.label}
            <ChevronDown className="lucide-icon dd-arrow" aria-hidden="true" size={20} strokeWidth={2} />
          </a>
          <div class="dropdown-menu" role="menu">
            {dd.items.map((item) => (
              <a
                href={item.href}
                class={`dropdown-item ${currentPath === item.href ? 'active' : ''}`}
                role="menuitem"
                aria-current={currentPath === item.href ? 'page' : undefined}
              >{item.label}</a>
            ))}
          </div>
        </div>
      ))}
      <a href="/about" class={`nav-link ${currentPath === '/about' ? 'active' : ''}`} aria-current={currentPath === '/about' ? 'page' : undefined}>About</a>
      <a href="/testimonials" class={`nav-link ${currentPath === '/testimonials' ? 'active' : ''}`} aria-current={currentPath === '/testimonials' ? 'page' : undefined}>Testimonials</a>
    </nav>

    <!-- CTA -->
    <div class="nav-actions">
      <a
        href={`https://wa.me/923010910933?text=${encodeURIComponent('Hi, I need an ADA compliance audit for my website.')}`}
        class="btn btn-primary"
        target="_blank"
        rel="noopener noreferrer"
        id="nav-cta-btn"
      >
        <PhoneCall className="lucide-icon" style={{ fontSize: '1rem' }} aria-hidden="true" size={20} strokeWidth={2} />
        Free Quote
      </a>

      <!-- Mobile Hamburger -->
      <button class="hamburger" id="hamburger-btn" aria-label="Toggle mobile menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Mobile navigation">
    <a href="/" class={`mobile-link ${currentPath === '/' ? 'active' : ''}`}>Home</a>
    {dropdowns.map((dd) => (
      <>
        <div class="mobile-section-label">{dd.label}</div>
        {dd.items.map((item) => (
          <a href={item.href} class={`mobile-link mobile-link-sub ${currentPath === item.href ? 'active' : ''}`}>
            {item.label}
          </a>
        ))}
      </>
    ))}
    <a href="/about" class={`mobile-link ${currentPath === '/about' ? 'active' : ''}`}>About</a>
    <a href="/testimonials" class={`mobile-link ${currentPath === '/testimonials' ? 'active' : ''}`}>Testimonials</a>
    <a
      href={`https://wa.me/923010910933?text=${encodeURIComponent('Hi, I need an ADA compliance audit for my website.')}`}
      class="btn btn-primary"
      target="_blank"
      rel="noopener noreferrer"
      style="margin-top:12px;"
    >
      Get Free Quote
    </a>
  </div>
</header>

<script>
  // Sticky on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) header?.classList.add('scrolled');
    else header?.classList.remove('scrolled');
  }, { passive: true });

  // Hamburger
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.classList.toggle('open', isOpen);
  });
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 0.25s var(--ease);
  }
  .site-nav.scrolled {
    box-shadow: 0 2px 20px rgba(15,15,15,0.08);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 68px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-icon {
    color: var(--accent);
    font-size: 1.5rem;
  }
  .logo-text {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .logo-text strong {
    color: var(--accent);
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 3px;
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: all 0.2s var(--ease);
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--accent); background: var(--accent-lt); }
  .nav-link.active { color: var(--accent); background: var(--accent-lt); font-weight: 600; }
  .dd-arrow { font-size: 1rem; transition: transform 0.2s; }
  .nav-dropdown { position: relative; }
  .nav-dropdown:hover .dd-arrow { transform: rotate(180deg); }
  .dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 30px rgba(15,15,15,0.12);
    padding: 8px;
    min-width: 220px;
    z-index: 200;
  }
  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu { display: flex; flex-direction: column; }
  .dropdown-item {
    padding: 9px 12px;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: var(--ink-2);
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .dropdown-item:hover, .dropdown-item.active { background: var(--accent-lt); color: var(--accent); }
  .mobile-section-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 10px 0 4px;
    margin-top: 4px;
    border-top: 1px solid var(--border);
  }
  .mobile-link-sub { padding-left: 12px; font-size: 0.88rem; }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: var(--radius-sm);
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: all 0.25s var(--ease);
  }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 12px 24px 20px;
    border-top: 1px solid var(--border);
    background: var(--white);
  }
  .mobile-menu.open { display: flex; }
  .mobile-link {
    padding: 11px 0;
    color: var(--ink-2);
    font-size: 0.95rem;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 0.18s;
  }
  .mobile-link:hover, .mobile-link.active { color: var(--accent); }

  @media (max-width: 780px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .nav-actions .btn { display: none; }
  }
</style>
