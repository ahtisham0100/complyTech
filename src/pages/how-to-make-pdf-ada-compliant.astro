---
import { FileText, Zap } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import FAQAccordion from '../components/FAQAccordion.tsx';

const DOMAIN = 'https://adacomplianceservices.tech';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Make a PDF ADA Compliant",
    "description": "Step-by-step guide to making PDF documents ADA accessible, including tagging, reading order, alt text, color contrast, and document structure requirements.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Use a native text-based source", "text": "Always create PDFs from a text-based original document (Word, InDesign, Google Docs) rather than scanning a printed document. Scanned PDFs are images with no accessible text." },
      { "@type": "HowToStep", "position": 2, "name": "Add document title and language", "text": "In Document Properties, set a descriptive Title and the document Language. Screen readers announce language to users, which affects pronunciation rules." },
      { "@type": "HowToStep", "position": 3, "name": "Add heading structure", "text": "Use PDF heading tags (H1, H2, H3) to organize content. This enables screen reader users to navigate by heading and understand document structure." },
      { "@type": "HowToStep", "position": 4, "name": "Add alt text to all images", "text": "Every meaningful image must have descriptive alt text via the tag properties. Decorative images should be marked as artifacts so screen readers skip them." },
      { "@type": "HowToStep", "position": 5, "name": "Set correct reading order", "text": "Use the Reading Order tool in Adobe Acrobat to verify the logical reading sequence of all content. Multi-column layouts, sidebars, and tables frequently have incorrect reading order." },
      { "@type": "HowToStep", "position": 6, "name": "Make tables accessible", "text": "Tag tables with proper Table, TR, TH, and TD structure. Header cells must be correctly designated as row or column headers so screen readers announce the appropriate context." },
      { "@type": "HowToStep", "position": 7, "name": "Verify color contrast", "text": "All text in the PDF must meet WCAG 4.5:1 contrast ratio against its background. Use a contrast checker to verify all text colors." },
      { "@type": "HowToStep", "position": 8, "name": "Run accessibility checker and remediate", "text": "Use Adobe Acrobat's built-in accessibility checker to identify remaining issues. Address all errors before distributing the document." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Are PDF documents required to be ADA accessible?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. PDFs posted on a public website — menus, brochures, forms, guides, reports — must be accessible under ADA Title III if they are considered part of the public accommodation. Inaccessible PDFs are among the most commonly cited ADA violations across all industries, particularly for restaurants (menus), law firms (articles), healthcare (patient forms), and government agencies." } },
      { "@type": "Question", "name": "Can a scanned PDF be made ADA compliant?", "acceptedAnswer": { "@type": "Answer", "text": "A scanned PDF (an image of a printed document) is the hardest to make accessible. OCR (Optical Character Recognition) can extract text, but the resulting document usually requires extensive manual tagging — reading order correction, heading structure, table markup, alt text, and contrast verification. In most cases, recreating the document from a text-based source (Word or InDesign) is faster and produces better results than OCR-based remediation." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": DOMAIN },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": `${DOMAIN}/services` },
      { "@type": "ListItem", "position": 3, "name": "PDF Accessibility Guide", "item": `${DOMAIN}/how-to-make-pdf-ada-compliant` }
    ]
  }
];

const faqItems = [
  { question: "Are PDFs on my website required to be ADA accessible?", answer: "Yes. PDFs posted on a public website — menus, brochures, forms, guides, reports — must be accessible under ADA Title III if they are part of your public accommodation. Inaccessible PDFs are among the most commonly cited ADA violations across all industries, particularly for restaurants (menus), law firms (articles), healthcare (patient forms), and government agencies." },
  { question: "Can a scanned PDF be made ADA compliant?", answer: "A scanned PDF (an image of a printed page) is difficult to remediate. OCR can extract text, but the result typically requires extensive manual tagging — reading order, headings, tables, alt text, contrast. In most cases, recreating from a text-based source (Word, InDesign) is faster and produces better results than OCR remediation of scanned files." },
  { question: "What tools are used to remediate PDFs?", answer: "The primary tool for PDF accessibility remediation is Adobe Acrobat Pro (paid). Free options include the PAC (PDF Accessibility Checker) for testing, and LibreOffice for creating accessible PDFs from scratch. For Word-to-PDF workflows, Microsoft Word's built-in accessibility checker should be run before export, and Acrobat Pro used to verify and correct the final PDF." },
  { question: "What is the difference between a tagged and untagged PDF?", answer: "A tagged PDF contains behind-the-scenes structural markup (tags) that screen readers use to understand content — headings, paragraphs, lists, tables, images with alt text, reading order. An untagged PDF has no structural information — screen readers read content in the order it appears in the file, which is often wrong, and cannot identify headings, lists, or image descriptions." },
  { question: "Does complyTech offer PDF remediation services?", answer: "Yes. complyTech offers PDF accessibility remediation as a standalone service and as an add-on to full website audits. PDF remediation pricing depends on document complexity — typically $50–$300 per document for standard business PDFs. Volume discounts are available. Contact us on WhatsApp with your document list for a quote." }
];

const steps = [
  { num: 1, title: 'Start from a text-based source', detail: 'Always create PDFs from a text-based original (Word, InDesign, Google Docs). Never scan a printed document — scanned PDFs are images with zero accessible text.' },
  { num: 2, title: 'Set document title and language', detail: 'In File → Properties → Description, add a descriptive document title. In File → Properties → Advanced, set the Language. Screen readers announce both to users.' },
  { num: 3, title: 'Apply heading structure (H1, H2, H3)', detail: 'Use proper heading tags in your source document before export, then verify in Acrobat Pro using the Tags panel. Heading structure enables document navigation for screen reader users.' },
  { num: 4, title: 'Add alt text to all meaningful images', detail: 'Right-click each image in Acrobat → Edit Alt Text. Describe the information the image conveys. Mark decorative images as Background Artifact so screen readers skip them.' },
  { num: 5, title: 'Fix reading order', detail: 'Use the Reading Order tool (Tools → Accessibility → Reading Order) to verify content order matches the visual reading sequence. Multi-column layouts and sidebars are common failure points.' },
  { num: 6, title: 'Tag tables properly', detail: 'Tables need Table, TR, TH, and TD tags with proper header scope. Use the Table Editor in Acrobat to set row/column header designations. Merged cells require special attention.' },
  { num: 7, title: 'Verify color contrast (4.5:1 ratio required)', detail: 'Check all text against its background using a color contrast analyzer. PDFs using light text on colored backgrounds or colored text on white are frequent failures.' },
  { num: 8, title: 'Run and resolve Acrobat accessibility check', detail: 'In Acrobat Pro: Tools → Accessibility → Full Check. Resolve all errors (red X items). Address warnings where possible. Document remaining exceptions with justification.' },
];
---

<BaseLayout
  title="How to Make a PDF ADA Compliant | complyTech"
  description="Free 2026 guide: how to make PDFs ADA compliant with proper tagging, reading order, and alt text. Professional PDF remediation available starting at $50 per document."
  canonical={`${DOMAIN}/how-to-make-pdf-ada-compliant`}
  schema={schema}
  ogType="article"
  keywords="how to make PDF ADA compliant, PDF accessibility guide, accessible PDF requirements, PDF WCAG compliance, ADA compliant PDF checklist"
>
  <Nav slot="nav" />

  <section class="page-hero" aria-labelledby="page-h1">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep" aria-hidden="true">›</span>
        <a href="/what-is-ada-compliance-websites">Resources</a><span class="sep" aria-hidden="true">›</span>
        <span class="current">PDF Accessibility</span>
      </nav>
      <div class="hero-badge">
        <FileText className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} />
        8-Step Guide · Menus · Forms · Legal Documents
      </div>
      <h1 id="page-h1">How to Make a PDF ADA Compliant: Complete Guide</h1>
      <p class="hero-sub">PDFs on your website — menus, forms, guides, brochures — must meet ADA accessibility standards. This 8-step guide covers what's required, what tools to use, and when to call in professional PDF remediation services.</p>
      <div class="hero-actions">
        <a href="#steps" class="btn btn-whatsapp btn-lg" id="hero-pdf-cta">See 8-Step Guide</a>
        <a href="#cta" class="btn btn-outline-light btn-lg">Get PDF Remediation Quote</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="page-layout">
        <article class="prose-section">

          <div class="tldr-box" role="note">
            <div class="tldr-label"><Zap className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} />TL;DR</div>
            <ul>
              <li>PDFs on public websites must be ADA accessible — menus, forms, brochures, guides all count.</li>
              <li>Scanned PDF images are completely inaccessible — recreate from text-based source when possible.</li>
              <li>Key requirements: document tags, heading structure, alt text, correct reading order, table markup, color contrast.</li>
              <li>Primary remediation tool: Adobe Acrobat Pro (PDF accessibility checker built in).</li>
              <li>Professional PDF remediation typically costs $50–$300 per document.</li>
            </ul>
          </div>

          <h2>Why PDF Accessibility Matters for ADA Compliance</h2>
          <p>PDFs are one of the most commonly cited ADA accessibility failures across all industries. When a user who relies on a screen reader downloads your menu, intake form, annual report, or service guide — that PDF must be readable by their assistive technology. A scanned image or an untagged PDF is completely opaque to screen readers and braille displays.</p>
          <p>Industries where PDF accessibility violations are most frequently cited:</p>
          <ul>
            <li><strong>Restaurants</strong> — menus posted as scanned PDFs</li>
            <li><strong>Law firms</strong> — newsletters, articles, client guides</li>
            <li><strong>Healthcare</strong> — patient intake forms, health information sheets</li>
            <li><strong>Financial services</strong> — account statements, investment guides</li>
            <li><strong>Government agencies</strong> — required under Section 508</li>
          </ul>

          <h2 id="steps">8-Step PDF Accessibility Guide</h2>
          <div class="step-list">
            {steps.map((step) => (
              <div class="step-item">
                <div class="step-num" aria-hidden="true">{step.num}</div>
                <div class="step-content">
                  <h4>{step.title}</h4>
                  <p>{step.detail}</p>
                </div>
              </div>
            ))}
          </div>

          <h2>PDF Accessibility Tools</h2>
          <div class="table-wrapper">
            <table class="prose-table" aria-label="PDF accessibility tools comparison">
              <thead><tr><th scope="col">Tool</th><th scope="col">Purpose</th><th scope="col">Cost</th></tr></thead>
              <tbody>
                <tr><td><strong>Adobe Acrobat Pro</strong></td><td>Full remediation — tagging, reading order, alt text, table editor, accessibility checker</td><td>$19.99/mo</td></tr>
                <tr><td><strong>PAC (PDF Accessibility Checker)</strong></td><td>Free testing tool — identifies failures against PDF/UA and WCAG</td><td>Free</td></tr>
                <tr><td><strong>Microsoft Word</strong></td><td>Built-in accessibility checker before export — best starting point for Word-to-PDF workflows</td><td>Subscription</td></tr>
                <tr><td><strong>Adobe InDesign</strong></td><td>Export tagged PDFs from design files — best for complex documents</td><td>Creative Cloud</td></tr>
                <tr><td><strong>CommonLook PDF</strong></td><td>Enterprise PDF remediation tool — batch processing for volume documents</td><td>Enterprise</td></tr>
              </tbody>
            </table>
          </div>

          <h2 id="faq-pdf">Frequently Asked Questions</h2>
          <FAQAccordion items={faqItems} client:load />

        </article>

        <aside class="page-sidebar">
          <div class="sidebar-card">
            <h4>PDF Remediation Service</h4>
            <p>Don't have time to remediate PDFs yourself? We handle full PDF accessibility remediation starting at $50 per document.</p>
            <a href={`https://wa.me/923010910933?text=${encodeURIComponent('Hi, I need PDF accessibility remediation for my documents.')}`} class="btn btn-primary" target="_blank" rel="noopener noreferrer" style="width:100%;justify-content:center;" id="sidebar-pdf-cta">Chat on WhatsApp</a>
          </div>
          <div class="sidebar-card">
            <h4>Related Resources</h4>
            <ul class="sidebar-links">
              <li><a href="/ada-compliance-restaurants">Restaurant Menu Compliance</a></li>
              <li><a href="/ada-compliance-law-firms">Law Firm PDF Compliance</a></li>
              <li><a href="/ada-compliance-healthcare-websites">Healthcare Form Compliance</a></li>
              <li><a href="/ada-compliance-checklist-2025">Full ADA Checklist</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <CTASection heading="Need Professional PDF Accessibility Remediation?" subtext="Our team handles full PDF remediation — tagging, reading order, alt text, tables, contrast — starting at $50 per document. Volume discounts available for bulk document sets." />

  <section class="section section-sm" style="background: var(--surface); border-top: 1px solid var(--border);">
    <div class="container">
      <h2 style="text-align:center;margin-bottom:12px;">Industries That Need PDF Accessibility</h2>
      <p style="text-align:center;max-width:560px;margin:0 auto 32px;color:var(--ink-2);font-size:0.92rem;">PDF accessibility issues are common across these industries. <a href="/industries">View all industry guides</a>.</p>
      <div class="related-industry-grid">
        <a href="/ada-compliance-restaurants" class="rel-ind-card"><strong>Restaurants</strong><span>Menu PDFs — the #1 cited violation</span></a>
        <a href="/ada-compliance-law-firms" class="rel-ind-card"><strong>Law Firms</strong><span>Newsletters, articles, legal guides</span></a>
        <a href="/ada-compliance-healthcare-websites" class="rel-ind-card"><strong>Healthcare</strong><span>Patient forms, health information</span></a>
        <a href="/ada-compliance-dental-offices" class="rel-ind-card"><strong>Dental Offices</strong><span>New patient packets, insurance</span></a>
        <a href="/ada-compliance-for-nonprofits" class="rel-ind-card"><strong>Nonprofits</strong><span>Annual reports, program guides</span></a>
        <a href="/section-508-compliance" class="rel-ind-card"><strong>Government</strong><span>Section 508 mandatory compliance</span></a>
      </div>
      <p style="text-align:center;margin-top:24px;font-size:0.88rem;"><a href="/services">View all services</a> · <a href="/vpat-documentation-services">VPAT Documentation</a> · <a href="/ada-compliance-audit-small-business">Full Audit Details</a></p>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .btn-outline-light { background: transparent; color: rgba(255,255,255,0.9); border-color: rgba(255,255,255,0.4); }
  .btn-outline-light:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.7); color: #fff; }
  .sidebar-links { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .sidebar-links li a { font-size: 0.88rem; color: var(--accent-2); }
  .sidebar-links li a::before { content: '› '; }
  @media (max-width: 900px) {
    .page-layout { grid-template-columns: 1fr; }
    .page-sidebar { position: static; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  }
  @media (max-width: 600px) { .page-sidebar { grid-template-columns: 1fr; } }
</style>
