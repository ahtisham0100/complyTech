---
import { ShieldCheck, ArrowRight, CheckCircle2, Search, Hospital, BookOpen } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';

const waLink = `https://wa.me/923010910933?text=${encodeURIComponent('Hi, I need an ADA compliance audit for my website.')}`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "complyTech",
    "url": "https://adacomplianceservices.tech",
    "telephone": "+923010910933",
    "description": "ADA compliance services agency specializing in WCAG 2.2 website accessibility audits, remediation, and certification for businesses across the United States.",
    "serviceArea": "United States",
    "knowsAbout": ["ADA Compliance","WCAG 2.2","Web Accessibility","Section 508","Section 1557","Accessibility Auditing","VPAT"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "complyTech",
    "url": "https://adacomplianceservices.tech"
  }
];

const services = [
  {
    icon: Search,
    href: '/ada-compliance-audit-small-business',
    title: 'ADA Audit for Small Business',
    desc: 'Identify every WCAG 2.2 violation with a full manual expert review — automated tools miss 60–70% of issues. Delivery in 5–14 business days.',
    badge: 'Most Popular',
  },
  {
    icon: Hospital,
    href: '/ada-compliance-healthcare-websites',
    title: 'Healthcare Website Compliance',
    desc: 'Patient portals, telehealth, and appointment systems face dual liability under ADA and Section 1557 of the ACA. Specialized audit coverage.',
    badge: 'Highest Revenue',
  },
  {
    icon: BookOpen,
    href: '/what-is-ada-compliance-websites',
    title: 'What Is ADA Compliance?',
    desc: 'Our complete 2025 guide covers what ADA requires, who it applies to, WCAG explained, penalties, and how to achieve compliance affordably.',
    badge: 'Free Resource',
  },
];
---

<BaseLayout
  title="complyTech — ADA Compliance Audit Services | WCAG 2.2 Experts"
  description="Stop worrying about ADA lawsuits. complyTech delivers certified WCAG 2.2 website accessibility audits for small businesses, healthcare, and e-commerce. Free quotes via WhatsApp."
  canonical="https://adacomplianceservices.tech"
  schema={schema}
>
  <Nav slot="nav" />

  <!-- ═══ HOME HERO ═══════════════════════════════════════════════════════ -->
  <section class="home-hero" aria-labelledby="hero-headline">
    <div class="container hero-content">

      <div class="hero-badge-row">
        <span class="hero-badge">
          <ShieldCheck className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} />
          IAAP-Certified Accessibility Specialists
        </span>
      </div>

      <h1 id="hero-headline">
        Your Website Has ADA Violations.<br/>
        <em>We Find &amp; Fix Every One.</em>
      </h1>

      <p class="hero-sub">
        Over 4,000 ADA website lawsuits were filed in 2024. Small businesses are the #1 target — with settlements averaging <strong>$12,000–$75,000</strong>. complyTech delivers complete WCAG 2.2 manual audits that automated tools can't match.
      </p>

      <div class="hero-actions">
        <a href={waLink} class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener noreferrer" id="hero-cta-primary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Get Free Quote on WhatsApp
        </a>
        <a href="/what-is-ada-compliance-websites" class="btn btn-outline btn-outline-hero btn-lg" id="hero-learn-more-btn">
          Learn More<span class="sr-only"> about ADA Compliance</span>
          <ArrowRight className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} />
        </a>
      </div>

      <div class="hero-trust">
        <span><CheckCircle2 className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} /> WCAG 2.2 Level AA</span>
        <span><CheckCircle2 className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} /> VPAT Included</span>
        <span><CheckCircle2 className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} /> Compliance Certificate</span>
        <span><CheckCircle2 className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} /> 1-Day Response</span>
      </div>
    </div>
  </section>

  <!-- ═══ STATS BAR ════════════════════════════════════════════════════════ -->
  <section class="stats-section section-sm" aria-label="ADA compliance statistics">
    <div class="container">
      <div class="stats-bar">
        <div class="stat-item">
          <span class="stat-number">4,000+</span>
          <span class="stat-label">ADA federal lawsuits<br/>filed in 2024 alone</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">$75K</span>
          <span class="stat-label">Average ADA lawsuit<br/>settlement cost</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">30–40%</span>
          <span class="stat-label">Issues detected by<br/>automated tools</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">82%</span>
          <span class="stat-label">Of targets are<br/>small businesses</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ══════════════════════════════════════════════════════════ -->
  <section class="section services-section" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-intro">
        <p class="section-eyebrow">What We Do</p>
        <h2 id="services-heading">ADA Compliance Services</h2>
        <p class="section-sub">Comprehensive accessibility audits and remediation for businesses of every size and industry.</p>
      </div>

      <div class="services-grid">
        {services.map((s) => (
          <a href={s.href} class="service-card" id={`service-card-${s.icon}`}>
            {s.badge && <span class="service-badge">{s.badge}</span>}
            <div class="service-icon">
              {(() => { const Icon = s.icon; return <Icon className="lucide-icon" aria-hidden="true" size={28} strokeWidth={2} />; })()}
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <span class="learn-more">
              Explore
              <ArrowRight className="lucide-icon" aria-hidden="true" size={20} strokeWidth={2} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TRUST SECTION ═════════════════════════════════════════════════════ -->
  <section class="trust-section section-sm" aria-labelledby="trust-heading">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-text">
          <h2 id="trust-heading">Why Businesses Choose complyTech</h2>
          <p>Unlike automated scanners, our IAAP-certified team conducts full manual screen reader testing, keyboard navigation audits, and cognitive accessibility reviews — catching the 60–70% of violations that automated tools miss entirely.</p>
          <ul class="checklist" style="margin-top:16px;">
            <li><span class="check-icon" aria-hidden="true">✓</span> Full WCAG 2.2 Level AA manual review</li>
            <li><span class="check-icon" aria-hidden="true">✓</span> VPAT (Voluntary Product Accessibility Template) included</li>
            <li><span class="check-icon" aria-hidden="true">✓</span> Compliance certificate after re-test</li>
            <li><span class="check-icon" aria-hidden="true">✓</span> Developer-ready fix guide with code examples</li>
            <li><span class="check-icon" aria-hidden="true">✓</span> 60-minute findings walkthrough call</li>
          </ul>
        </div>
        <div class="trust-visual">
          <div class="coverage-card">
            <div class="coverage-label">What Automated Tools Miss</div>
            <div class="coverage-bar-group">
              <div class="coverage-bar-row">
                <span class="cov-label">Automated Tools</span>
                <div class="cov-bar-wrap">
                  <div class="cov-bar cov-auto" style="width:35%" role="img" aria-label="35% detection rate for automated tools"></div>
                  <span class="cov-pct">30–40%</span>
                </div>
              </div>
              <div class="coverage-bar-row">
                <span class="cov-label">Manual Expert Audit</span>
                <div class="cov-bar-wrap">
                  <div class="cov-bar cov-manual" style="width:100%" role="img" aria-label="100% detection rate for manual expert audit"></div>
                  <span class="cov-pct">100%</span>
                </div>
              </div>
            </div>
            <p class="coverage-note">Source: Deque Systems accessibility research</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══════════════════════════════════════════════════════════════ -->
  <CTASection />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Hero */
  .hero-content { position: relative; z-index: 1; max-width: 760px; }
  .hero-badge-row { margin-bottom: 24px; }
  .home-hero h1 {
    color: #fff;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .home-hero h1 em { font-style: italic; color: #7ed4a0; }
  .home-hero .hero-sub {
    color: rgba(255,255,255,0.78);
    font-size: 1.1rem;
    max-width: 620px;
    margin-bottom: 32px;
    line-height: 1.7;
  }
  .home-hero .hero-sub strong { color: #fbbf24; font-weight: 700; }
  .btn-outline-hero {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.4);
  }
  .btn-outline-hero:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.7);
    color: #fff;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 28px;
    margin-top: 32px;
  }
  .hero-trust span {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.65);
    font-size: 0.85rem;
  }
  .hero-trust .lucide-icon { color: #7ed4a0; }

  /* Stats */
  .stats-section { background: var(--surface); }
  .stats-section .stats-bar { margin: 0; }

  /* Services */
  .section-intro { text-align: center; max-width: 560px; margin: 0 auto 8px; }
  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-2);
    margin-bottom: 8px;
  }
  .section-sub { color: var(--ink-3); font-size: 1rem; margin: 8px 0 0; }
  .service-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--accent-lt);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 3px 10px;
    border-radius: 20px;
    text-transform: uppercase;
  }

  /* Trust Section */
  .trust-section { background: var(--surface); }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: center;
  }
  .trust-text h2 { margin-bottom: 14px; }
  .trust-text p { color: var(--ink-2); }
  .coverage-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-sm);
  }
  .coverage-label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 20px;
  }
  .coverage-bar-group { display: flex; flex-direction: column; gap: 16px; }
  .coverage-bar-row { display: flex; flex-direction: column; gap: 6px; }
  .cov-label { font-size: 0.85rem; font-weight: 500; color: var(--ink-2); }
  .cov-bar-wrap { display: flex; align-items: center; gap: 10px; }
  .cov-bar { height: 14px; border-radius: 7px; transition: width 1s var(--ease); }
  .cov-auto { background: linear-gradient(to right, #fbbf24, #f59e0b); flex-shrink: 0; }
  .cov-manual { background: linear-gradient(to right, var(--accent), var(--accent-2)); flex-shrink: 0; }
  .cov-pct { font-size: 0.82rem; font-weight: 700; color: var(--ink-2); white-space: nowrap; }
  .coverage-note { font-size: 0.78rem; color: var(--ink-2); margin-top: 16px; font-style: italic; }

  @media (max-width: 900px) {
    .trust-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
    .hero-trust { gap: 10px 20px; }
  }
</style>
